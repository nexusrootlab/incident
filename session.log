  "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>NEXUS ROOT LAB — Systems Security Research</title>\n  <meta name=\"description\" content=\"Dark-mode terminal-aesthetic portfolio for systems security research, kernel exploitation, and zero-day discovery.\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Rajdhani:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n  <link rel=\"stylesheet\" href=\"/css/style.css\">\n</head>\n<body id=\"top\">\n  <div class=\"scanline-overlay\" aria-hidden=\"true\"></div>\n\n  <nav class=\"nav-main\" role=\"navigation\" aria-label=\"Main navigation\">\n    <div class=\"nav-inner\">\n      <a href=\"/\" class=\"nav-logo\" aria-label=\"Nexus Root Lab home\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\"/></svg>\n        NEXUS ROOT LAB\n      </a>\n      <div class=\"nav-links\">\n        <a href=\"/#about\" class=\"nav-link\">About</a>\n        <a href=\"/#projects\" class=\"nav-link\">Projects</a>\n        <a href=\"/blog/\" class=\"nav-link\">Blog</a>\n        <a href=\"/#contact\" class=\"nav-link\">Contact</a>\n      </div>\n    </div>\n  </nav>\n\n  <section class=\"hero\" id=\"hero\">\n    <div class=\"hero-grid\" aria-hidden=\"true\"></div>\n    <div class=\"container\">\n      <div class=\"hero-content\">\n        <div class=\"hero-prefix\">\n          <span>&gt; initializing research_env.sh</span>\n          <span class=\"cursor\" aria-hidden=\"true\"></span>\n        </div>\n        <h1 class=\"hero-title\">SYSTEMS<br><span class=\"line-accent\">SECURITY</span><br>RESEARCH</h1>\n        <p class=\"hero-subtitle\">Kernel exploitation &middot; Vulnerability research &middot; Zero-day discovery<br>Exploring the boundaries between hardware and software security.</p>\n        <div class=\"hero-cta\">\n          <a href=\"/#projects\" class=\"btn btn-primary\">\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg>\n            View Projects\n          </a>\n          <a href=\"/#contact\" class=\"btn btn-ghost\">\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"/><polyline points=\"22,6 12,13 2,6\"/></svg>\n            Get in Touch\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"about\">\n    <div class=\"container\">\n      <div class=\"section-label\">// about</div>\n      <h2 class=\"section-title\">Mission Brief</h2>\n      <hr class=\"divider\">\n      <div class=\"about-grid\">\n        <div class=\"about-text\">\n          <h3>Research Focus</h3>\n          <p>Specializing in low-level systems security — from boot firmware and kernel space to userspace exploitation. My work spans vulnerability discovery, exploit development, defensive tooling, and security architecture review across Linux, BSD, and proprietary RTOS environments.</p>\n          <p>Currently investigating hardware-assisted security mechanisms, confidential computing boundaries, and supply chain integrity in embedded systems. Every project is an exercise in understanding how systems fail — and how to make them fail better.</p>\n          <div class=\"stats-grid\">\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg></div>\n              <div class=\"stat-number\">47</div>\n              <div class=\"stat-label\">CVEs Filed</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\"/></svg></div>\n              <div class=\"stat-number\">12</div>\n              <div class=\"stat-label\">Open Source Tools</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"/><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"/></svg></div>\n              <div class=\"stat-number\">8</div>\n              <div class=\"stat-label\">Publications</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"/><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"/></svg></div>\n              <div class=\"stat-number\">3</div>\n              <div class=\"stat-label\">Conference Talks</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg></div>\n              <div class=\"stat-number\">9</div>\n              <div class=\"stat-label\">Years Experience</div>\n            </div>\n          </div>\n        </div>\n        <div class=\"skills-list\">\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z\"/></svg></div>\n            <div class=\"skill-info\"><h4>Reverse Engineering</h4><p>Binary analysis, firmware RE, protocol reconstruction</p></div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg></div>\n            <div class=\"skill-info\"><h4>Exploit Development</h4><p>Memory corruption, ROP chains, kernel exploitation</p></div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z\"/><line x1=\"4\" y1=\"22\" x2=\"4\" y2=\"15\"/></svg></div>\n            <div class=\"skill-info\"><h4>Red Team Operations</h4><p>Adversary simulation, persistence, C2 infrastructure</p></div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\"><svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z\"/></svg></div>\n            <div class=\"skill-info\"><h4>Kernel Security</h4><p>Linux/BSD kernel auditing, driver fuzzing, LSM</p></div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/><polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"/><line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"/></svg></div>\n            <div class=\"skill-info\"><h4>Firmware Analysis</h4><p>UEFI/BIOS auditing, embedded systems RE, JTAG</p></div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\"><svg viewBox=\"0 0 24 24\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg></div>\n            <div class=\"skill-info\"><h4>Security Architecture</h4><p>Threat modeling, secure design review, hardening</p></div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"experience\">\n    <div class=\"container\">\n      <div class=\"section-label\">// career_trace</div>\n      <h2 class=\"section-title\">Experience</h2>\n      <hr class=\"divider\">\n      <div class=\"timeline\">\n        <div class=\"timeline-entry\">\n          <div class=\"timeline-date\">2021 — PRESENT</div>\n          <h3>Senior Security Researcher</h3>\n          <h4>Vertex Security Labs</h4>\n          <p>Leading kernel exploit research team. Discovered 12 CVEs in Linux network stack. Built automated vulnerability discovery pipeline processing 40k+ samples daily.</p>\n        </div>\n        <div class=\"timeline-entry\">\n          <div class=\"timeline-date\">2018 — 2021</div>\n          <h3>Security Engineer</h3>\n          <h4>Cipher Prime Inc.</h4>\n          <p>Red team operations and adversary simulation for Fortune 500 clients. Developed custom C2 framework and persistence mechanisms for authorized engagements.</p>\n        </div>\n        <div class=\"timeline-entry\">\n          <div class=\"timeline-date\">2017 — 2018</div>\n          <h3>Reverse Engineer</h3>\n          <h4>Apex Defense Group</h4>\n          <p>APT analysis and malware reverse engineering. Reconstructed attack chains for nation-state threat actors targeting critical infrastructure.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"projects\">\n    <div class=\"container\">\n      <div class=\"section-label\">// featured_work</div>\n      <h2 class=\"section-title\">Projects</h2>\n      <hr class=\"divider\">\n      <div class=\"projects-grid\">\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/kernel-shield\" class=\"project-external\" aria-label=\"View on GitHub\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg></a>\n          </div>\n          <h3>Kernel Shield</h3>\n          <p class=\"project-desc\">Runtime kernel integrity monitor using eBPF and hardware performance counters. Detects code modification attacks in real-time with sub-microsecond latency.</p>\n          <div class=\"project-tags\"><span class=\"tag\">C</span><span class=\"tag\">eBPF</span><span class=\"tag\">Linux</span><span class=\"tag\">Security</span></div>\n          <div class=\"project-links\"><a href=\"https://github.com/nexusrootlab/kernel-shield\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg> Source</a></div>\n        </article>\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/firmware-auditor\" class=\"project-external\" aria-label=\"View on GitHub\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg></a>\n          </div>\n          <h3>Firmware Auditor</h3>\n          <p class=\"project-desc\">Automated UEFI firmware analysis toolkit. Extracts, decompresses, and scans firmware volumes for known vulnerabilities, backdoors, and supply chain anomalies.</p>\n          <div class=\"project-tags\"><span class=\"tag\">Rust</span><span class=\"tag\">UEFI</span><span class=\"tag\">Analysis</span></div>\n          <div class=\"project-links\"><a href=\"https://github.com/nexusrootlab/firmware-auditor\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg> Source</a></div>\n        </article>\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"/><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/phantom-bridge\" class=\"project-external\" aria-label=\"View on GitHub\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg></a>\n          </div>\n          <h3>Phantom Bridge</h3>\n          <p class=\"project-desc\">Covert channel framework for authorized red team operations. Encodes C2 communications within legitimate network protocols using steganographic techniques.</p>\n          <div class=\"project-tags\"><span class=\"tag\">Go</span><span class=\"tag\">C2</span><span class=\"tag\">Red Team</span></div>\n          <div class=\"project-links\"><a href=\"https://github.com/nexusrootlab/phantom-bridge\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg> Source</a></div>\n        </article>\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><polyline points=\"16 18 22 12 16 6\"/><polyline points=\"8 6 2 12 8 18\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/spectre-toolkit\" class=\"project-external\" aria-label=\"View on GitHub\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg></a>\n          </div>\n          <h3>Spectre Toolkit</h3>\n          <p class=\"project-desc\">Collection of proof-of-concept exploits for transient execution vulnerabilities (Spectre, Meltdown, MDS). Educational reference for hardware security research.</p>\n          <div class=\"project-tags\"><span class=\"tag\">C</span><span class=\"tag\">ASM</span><span class=\"tag\">Hardware</span></div>\n          <div class=\"project-links\"><a href=\"https://github.com/nexusrootlab/spectre-toolkit\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg> Source</a></div>\n        </article>\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z\"/><line x1=\"4\" y1=\"22\" x2=\"4\" y2=\"15\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/logredact\" class=\"project-external\" aria-label=\"View on GitHub\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg></a>\n          </div>\n          <h3>Log Redact</h3>\n          <p class=\"project-desc\">Privacy-preserving log sanitizer for incident response. Automatically detects and redacts PII, credentials, and sensitive infrastructure details from security logs.</p>\n          <div class=\"project-tags\"><span class=\"tag\">Python</span><span class=\"tag\">Privacy</span><span class=\"tag\">IR</span></div>\n          <div class=\"project-links\"><a href=\"https://github.com/nexusrootlab/logredact\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg> Source</a></div>\n        </article>\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/hook-engine\" class=\"project-external\" aria-label=\"View on GitHub\"><svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg></a>\n          </div>\n          <h3>Hook Engine</h3>\n          <p class=\"project-desc\">Cross-platform function hooking library for security instrumentation. Supports inline hooks, IAT/EAT manipulation, and syscall interposition on Linux, macOS, and Windows.</p>\n          <div class=\"project-tags\"><span class=\"tag\">C++</span><span class=\"tag\">Hooks</span><span class=\"tag\">Cross-Platform</span></div>\n          <div class=\"project-links\"><a href=\"https://github.com/nexusrootlab/hook-engine\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg> Source</a></div>\n        </article>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"contact\">\n    <div class=\"container\">\n      <div class=\"section-label\">// signal_protocol</div>\n      <h2 class=\"section-title\">Contact</h2>\n      <hr class=\"divider\">\n      <div class=\"contact-grid\">\n        <div class=\"contact-info\">\n          <p>Interested in collaboration, responsible disclosure, or security research partnerships? Reach out through any of the channels below or use the contact form.</p>\n          <div class=\"contact-links\">\n            <a href=\"mailto:research@nexusrootlab.io\" class=\"contact-link\"><svg viewBox=\"0 0 24 24\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"/><polyline points=\"22,6 12,13 2,6\"/></svg>research@nexusrootlab.io</a>\n            <a href=\"https://github.com/nexusrootlab\" class=\"contact-link\"><svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg>github.com/nexusrootlab</a>\n            <a href=\"https://twitter.com/nexusrootlab\" class=\"contact-link\"><svg viewBox=\"0 0 24 24\"><path d=\"M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z\"/></svg>@nexusrootlab</a>\n            <a href=\"https://infosec.exchange/@nexusrootlab\" class=\"contact-link\"><svg viewBox=\"0 0 24 24\"><path d=\"M21 2H3v16h5v4l4-4h5l4-4V2zm-10 9V5m5 6V5\"/></svg>infosec.exchange/@nexusrootlab</a>\n          </div>\n        </div>\n        <div class=\"contact-form-wrapper\">\n          <h3>// send_transmission</h3>\n          <form action=\"https://formspree.io/f/yourformid\" method=\"POST\">\n            <div class=\"form-group\"><label for=\"name\">Handle</label><input type=\"text\" id=\"name\" name=\"name\" placeholder=\"your_handle\" required></div>\n            <div class=\"form-group\"><label for=\"email\">Email</label><input type=\"email\" id=\"email\" name=\"email\" placeholder=\"you@example.com\" required></div>\n            <div class=\"form-group\"><label for=\"message\">Message</label><textarea id=\"message\" name=\"message\" placeholder=\"&gt; begin transmission...\" required></textarea></div>\n            <button type=\"submit\" class=\"btn btn-primary\"><svg viewBox=\"0 0 24 24\"><line x1=\"22\" y1=\