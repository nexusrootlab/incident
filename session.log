{
  "content": "---\nlayout: null\n---\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>NEXUS ROOT LAB — Systems Security Research</title>\n  <meta name=\"description\" content=\"Dark-mode terminal-aesthetic portfolio for systems security research, kernel exploitation, and zero-day discovery.\">\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Rajdhani:wght@400;600;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\">\n  <link rel=\"stylesheet\" href=\"/css/style.css\">\n</head>\n<body id=\"top\">\n\n  <!-- Scanline overlay -->\n  <div class=\"scanline-overlay\" aria-hidden=\"true\"></div>\n\n  <!-- Navigation -->\n  <nav class=\"nav-main\" role=\"navigation\" aria-label=\"Main navigation\">\n    <div class=\"nav-inner\">\n      <a href=\"/\" class=\"nav-logo\" aria-label=\"Nexus Root Lab home\">\n        <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\"/></svg>\n        NEXUS ROOT LAB\n      </a>\n      <div class=\"nav-links\">\n        <a href=\"/#about\" class=\"nav-link\">About</a>\n        <a href=\"/#projects\" class=\"nav-link\">Projects</a>\n        <a href=\"/blog/\" class=\"nav-link\">Blog</a>\n        <a href=\"/#contact\" class=\"nav-link\">Contact</a>\n      </div>\n    </div>\n  </nav>\n\n  <!-- HERO -->\n  <section class=\"hero\" id=\"hero\">\n    <div class=\"hero-grid\" aria-hidden=\"true\"></div>\n    <div class=\"container\">\n      <div class=\"hero-content\">\n        <div class=\"hero-prefix\">\n          <span>&gt; initializing research_env.sh</span>\n          <span class=\"cursor\" aria-hidden=\"true\"></span>\n        </div>\n        <h1 class=\"hero-title\">\n          SYSTEMS<br>\n          <span class=\"line-accent\">SECURITY</span><br>\n          RESEARCH\n        </h1>\n        <p class=\"hero-subtitle\">\n          Kernel exploitation &middot; Vulnerability research &middot; Zero-day discovery<br>\n          Exploring the boundaries between hardware and software security.\n        </p>\n        <div class=\"hero-cta\">\n          <a href=\"/#projects\" class=\"btn btn-primary\">\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg>\n            View Projects\n          </a>\n          <a href=\"/#contact\" class=\"btn btn-ghost\">\n            <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\"><path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\"/><polyline points=\"22,6 12,13 2,6\"/></svg>\n            Get in Touch\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ABOUT -->\n  <section class=\"section\" id=\"about\">\n    <div class=\"container\">\n      <div class=\"section-label\">// about</div>\n      <h2 class=\"section-title\">Mission Brief</h2>\n      <hr class=\"divider\">\n\n      <div class=\"about-grid\">\n        <div class=\"about-text\">\n          <h3>Research Focus</h3>\n          <p>Specializing in low-level systems security — from boot firmware and kernel space to userspace exploitation. My work spans vulnerability discovery, exploit development, defensive tooling, and security architecture review across Linux, BSD, and proprietary RTOS environments.</p>\n          <p>Currently investigating hardware-assisted security mechanisms, confidential computing boundaries, and supply chain integrity in embedded systems. Every project is an exercise in understanding how systems fail — and how to make them fail better.</p>\n\n          <!-- Stats -->\n          <div class=\"stats-grid\">\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n              </div>\n              <div class=\"stat-number\">47</div>\n              <div class=\"stat-label\">CVEs Filed</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\"/></svg>\n              </div>\n              <div class=\"stat-number\">12</div>\n              <div class=\"stat-label\">Open Source Tools</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z\"/><path d=\"M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z\"/></svg>\n              </div>\n              <div class=\"stat-number\">8</div>\n              <div class=\"stat-label\">Publications</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\">\n                <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"2\" y1=\"12\" x2=\"22\" y2=\"12\"/><path d=\"M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z\"/></svg>\n              </div>\n              <div class=\"stat-number\">3</div>\n              <div class=\"stat-label\">Conference Talks</div>\n            </div>\n            <div class=\"stat-card\">\n              <div class=\"stat-icon\">\n                <svg viewBox=\"0 0 24 24\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>\n              </div>\n              <div class=\"stat-number\">9</div>\n              <div class=\"stat-label\">Years Experience</div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"skills-list\">\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z\"/></svg>\n            </div>\n            <div class=\"skill-info\">\n              <h4>Reverse Engineering</h4>\n              <p>Binary analysis, firmware RE, protocol reconstruction</p>\n            </div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n            </div>\n            <div class=\"skill-info\">\n              <h4>Exploit Development</h4>\n              <p>Memory corruption, ROP chains, kernel exploitation</p>\n            </div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z\"/><line x1=\"4\" y1=\"22\" x2=\"4\" y2=\"15\"/></svg>\n            </div>\n            <div class=\"skill-info\">\n              <h4>Red Team Operations</h4>\n              <p>Adversary simulation, persistence, C2 infrastructure</p>\n            </div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\">\n              <svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"3\"/><path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z\"/></svg>\n            </div>\n            <div class=\"skill-info\">\n              <h4>Kernel Security</h4>\n              <p>Linux/BSD kernel auditing, driver fuzzing, LSM</p>\n            </div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/><polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"/><line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"/></svg>\n            </div>\n            <div class=\"skill-info\">\n              <h4>Firmware Analysis</h4>\n              <p>UEFI/BIOS auditing, embedded systems RE, JTAG</p>\n            </div>\n          </div>\n          <div class=\"skill-row\">\n            <div class=\"skill-icon\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>\n            </div>\n            <div class=\"skill-info\">\n              <h4>Security Architecture</h4>\n              <p>Threat modeling, secure design review, hardening</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- EXPERIENCE -->\n  <section class=\"section\" id=\"experience\">\n    <div class=\"container\">\n      <div class=\"section-label\">// career_trace</div>\n      <h2 class=\"section-title\">Experience</h2>\n      <hr class=\"divider\">\n\n      <div class=\"timeline\">\n        <div class=\"timeline-entry\">\n          <div class=\"timeline-date\">2021 — PRESENT</div>\n          <h3>Senior Security Researcher</h3>\n          <h4>Vertex Security Labs</h4>\n          <p>Leading kernel exploit research team. Discovered 12 CVEs in Linux network stack. Built automated vulnerability discovery pipeline processing 40k+ samples daily.</p>\n        </div>\n        <div class=\"timeline-entry\">\n          <div class=\"timeline-date\">2018 — 2021</div>\n          <h3>Security Engineer</h3>\n          <h4>Cipher Prime Inc.</h4>\n          <p>Red team operations and adversary simulation for Fortune 500 clients. Developed custom C2 framework and persistence mechanisms for authorized engagements.</p>\n        </div>\n        <div class=\"timeline-entry\">\n          <div class=\"timeline-date\">2017 — 2018</div>\n          <h3>Reverse Engineer</h3>\n          <h4>Apex Defense Group</h4>\n          <p>APT analysis and malware reverse engineering. Reconstructed attack chains for nation-state threat actors targeting critical infrastructure.</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- FEATURED PROJECTS -->\n  <section class=\"section\" id=\"projects\">\n    <div class=\"container\">\n      <div class=\"section-label\">// featured_work</div>\n      <h2 class=\"section-title\">Projects</h2>\n      <hr class=\"divider\">\n\n      <div class=\"projects-grid\">\n\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/kernel-shield\" class=\"project-external\" aria-label=\"View on GitHub\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n            </a>\n          </div>\n          <h3>Kernel Shield</h3>\n          <p class=\"project-desc\">Runtime kernel integrity monitor using eBPF and hardware performance counters. Detects code modification attacks in real-time with sub-microsecond latency.</p>\n          <div class=\"project-tags\">\n            <span class=\"tag\">C</span>\n            <span class=\"tag\">eBPF</span>\n            <span class=\"tag\">Linux</span>\n            <span class=\"tag\">Security</span>\n          </div>\n          <div class=\"project-links\">\n            <a href=\"https://github.com/nexusrootlab/kernel-shield\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22\"/></svg>\n              Source\n            </a>\n          </div>\n        </article>\n\n        <article class=\"project-card\">\n          <div class=\"project-card-header\">\n            <svg viewBox=\"0 0 24 24\"><path d=\"M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z\"/></svg>\n            <a href=\"https://github.com/nexusrootlab/firmware-auditor\" class=\"project-external\" aria-label=\"View on GitHub\">\n              <svg viewBox=\"0 0 24 24\"><path d=\"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6\"/><polyline points=\"15 3 21 3 21 9\"/><line x1=\"10\" y1=\"14\" x2=\"21\" y2=\"3\"/></svg>\n            </a>\n          </div>\n          <h3>Firmware Auditor</h3>\n          <p class=\"project-desc\">Automated UEFI firmware analysis toolkit. Extracts, decompresses, and scans firmware volumes for known vulnerabilities, backdoors, and supply