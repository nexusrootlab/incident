  "content": "/* ============================================\n   NEXUS ROOT LAB — Dark Hacker Terminal Theme\n   Minimalist + Hacker-UI Hybrid\n   ============================================ */\n\n/* ---------- CUSTOM PROPERTIES ---------- */\n:root {\n  --bg-deep: #050507;\n  --bg-primary: #0a0a0f;\n  --bg-secondary: #0e0e16;\n  --bg-card: #111119;\n  --bg-elevated: #161622;\n  --text-primary: #b8b8cc;\n  --text-heading: #d4d4e4;\n  --text-accent: #00ff88;\n  --text-accent-alt: #00ccff;\n  --text-muted: #555577;\n  --border-subtle: #1a1a2e;\n  --border-accent: #00ff88;\n  --glow-accent: rgba(0, 255, 136, 0.15);\n  --glow-accent-strong: rgba(0, 255, 136, 0.35);\n  --glow-alt: rgba(0, 204, 255, 0.2);\n  --font-heading: 'Rajdhani', 'Courier New', monospace;\n  --font-mono: 'IBM Plex Mono', 'Fira Code', monospace;\n  --font-body: 'IBM Plex Mono', monospace;\n  --space-xs: 0.4rem;\n  --space-sm: 0.8rem;\n  --space-md: 1.6rem;\n  --space-lg: 2.4rem;\n  --space-xl: 4rem;\n  --space-2xl: 6rem;\n  --space-3xl: 8rem;\n  --radius: 2px;\n  --max-width: 1200px;\n  --transition-fast: 0.18s ease;\n  --transition-base: 0.3s ease;\n}\n\n/* ---------- RESET ---------- */\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  font-size: 16px;\n  scroll-behavior: smooth;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\nbody {\n  background-color: var(--bg-deep);\n  color: var(--text-primary);\n  font-family: var(--font-body);\n  font-size: 0.95rem;\n  line-height: 1.7;\n  letter-spacing: 0.02em;\n  overflow-x: hidden;\n}\n\na {\n  color: var(--text-accent);\n  text-decoration: none;\n  transition: color var(--transition-fast);\n}\n\na:hover {\n  color: var(--text-accent-alt);\n}\n\nimg {\n  max-width: 100%;\n  display: block;\n}\n\nul, ol {\n  list-style: none;\n}\n\n/* ---------- UTILITIES ---------- */\n.container {\n  width: 100%;\n  max-width: var(--max-width);\n  margin: 0 auto;\n  padding: 0 var(--space-md);\n}\n\n.section-label {\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.3em;\n  margin-bottom: var(--space-sm);\n}\n\n.section-title {\n  font-family: var(--font-heading);\n  font-size: clamp(1.8rem, 4vw, 2.8rem);\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: var(--text-heading);\n  line-height: 1.1;\n  margin-bottom: var(--space-lg);\n}\n\n.accent {\n  color: var(--text-accent);\n}\n\n.divider {\n  width: 60px;\n  height: 1px;\n  background: var(--text-accent);\n  border: none;\n  margin: var(--space-lg) 0;\n  box-shadow: 0 0 6px var(--glow-accent);\n}\n\n/* ---------- SCANLINE OVERLAY ---------- */\n.scanline-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  pointer-events: none;\n  z-index: 9999;\n  background: repeating-linear-gradient(\n    0deg,\n    transparent,\n    transparent 2px,\n    rgba(0, 255, 136, 0.012) 2px,\n    rgba(0, 255, 136, 0.012) 4px\n  );\n}\n\n/* ---------- ANIMATIONS ---------- */\n@keyframes terminalBlink {\n  0%, 49% { opacity: 1; }\n  50%, 100% { opacity: 0; }\n}\n\n@keyframes glitchFlicker {\n  0%, 92%, 100% { opacity: 1; transform: none; }\n  93% { opacity: 0.7; transform: translateX(-2px); }\n  94% { opacity: 1; transform: translateX(1px); }\n  95% { opacity: 0.9; transform: translateX(-1px); }\n  96% { opacity: 1; transform: none; }\n}\n\n@keyframes dataPulse {\n  0%, 100% { opacity: 0.4; }\n  50% { opacity: 1; }\n}\n\n@keyframes slideInUp {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes fadeIn {\n  from { opacity: 0; }\n  to { opacity: 1; }\n}\n\n@keyframes borderGlow {\n  0%, 100% { box-shadow: 0 0 4px var(--glow-accent); }\n  50% { box-shadow: 0 0 12px var(--glow-accent-strong); }\n}\n\n/* ---------- NAVIGATION ---------- */\n.nav-main {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  z-index: 1000;\n  background: rgba(5, 5, 7, 0.92);\n  backdrop-filter: blur(8px);\n  border-bottom: 1px solid var(--border-subtle);\n}\n\n.nav-inner {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  height: 56px;\n  padding: 0 var(--space-md);\n  max-width: var(--max-width);\n  margin: 0 auto;\n}\n\n.nav-logo {\n  font-family: var(--font-heading);\n  font-size: 1.1rem;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.15em;\n  color: var(--text-accent);\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n}\n\n.nav-logo svg {\n  width: 20px;\n  height: 20px;\n  fill: var(--text-accent);\n}\n\n.nav-links {\n  display: flex;\n  gap: var(--space-md);\n  align-items: center;\n}\n\n.nav-link {\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  text-transform: uppercase;\n  letter-spacing: 0.15em;\n  color: var(--text-muted);\n  transition: color var(--transition-fast);\n  position: relative;\n}\n\n.nav-link:hover,\n.nav-link.active {\n  color: var(--text-accent);\n}\n\n.nav-link::after {\n  content: '';\n  position: absolute;\n  bottom: -4px;\n  left: 0;\n  width: 0;\n  height: 1px;\n  background: var(--text-accent);\n  box-shadow: 0 0 4px var(--glow-accent);\n  transition: width var(--transition-base);\n}\n\n.nav-link:hover::after,\n.nav-link.active::after {\n  width: 100%;\n}\n\n/* ---------- HERO SECTION ---------- */\n.hero {\n  min-height: 85vh;\n  display: flex;\n  align-items: center;\n  padding-top: 56px;\n  position: relative;\n  overflow: hidden;\n}\n\n.hero-grid {\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);\n  background-size: 60px 60px;\n  mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);\n  animation: fadeIn 2s ease forwards;\n}\n\n.hero-content {\n  position: relative;\n  z-index: 1;\n  max-width: 720px;\n}\n\n.hero-prefix {\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.3em;\n  margin-bottom: var(--space-sm);\n  display: flex;\n  align-items: center;\n  gap: var(--space-xs);\n  animation: slideInUp 0.6s ease 0.2s both;\n}\n\n.hero-prefix .cursor {\n  display: inline-block;\n  width: 7px;\n  height: 14px;\n  background: var(--text-accent);\n  animation: terminalBlink 1s step-end infinite;\n}\n\n.hero-title {\n  font-family: var(--font-heading);\n  font-size: clamp(2.4rem, 7vw, 4.5rem);\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  color: var(--text-heading);\n  line-height: 1.05;\n  margin-bottom: var(--space-md);\n  animation: slideInUp 0.6s ease 0.4s both;\n}\n\n.hero-title .line-accent {\n  display: block;\n  color: var(--text-accent);\n  text-shadow: 0 0 20px var(--glow-accent);\n  animation: glitchFlicker 4s ease-in-out infinite;\n}\n\n.hero-subtitle {\n  font-family: var(--font-mono);\n  font-size: 0.9rem;\n  color: var(--text-muted);\n  line-height: 1.8;\n  max-width: 560px;\n  margin-bottom: var(--space-lg);\n  animation: slideInUp 0.6s ease 0.6s both;\n}\n\n.hero-cta {\n  display: flex;\n  gap: var(--space-sm);\n  flex-wrap: wrap;\n  animation: slideInUp 0.6s ease 0.8s both;\n}\n\n/* ---------- BUTTONS ---------- */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--space-xs);\n  padding: 0.7rem 1.4rem;\n  font-family: var(--font-mono);\n  font-size: 0.75rem;\n  text-transform: uppercase;\n  letter-spacing: 0.12em;\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  background: transparent;\n  color: var(--text-primary);\n  cursor: pointer;\n  transition: all var(--transition-fast);\n  text-decoration: none;\n}\n\n.btn svg {\n  width: 14px;\n  height: 14px;\n  fill: currentColor;\n}\n\n.btn-primary {\n  background: var(--text-accent);\n  color: var(--bg-deep);\n  border-color: var(--text-accent);\n}\n\n.btn-primary:hover {\n  background: transparent;\n  color: var(--text-accent);\n  box-shadow: 0 0 12px var(--glow-accent);\n}\n\n.btn-ghost:hover {\n  border-color: var(--text-accent);\n  color: var(--text-accent);\n  box-shadow: 0 0 8px var(--glow-accent);\n}\n\n/* ---------- SECTION CONTAINERS ---------- */\n.section {\n  padding: var(--space-3xl) 0;\n  position: relative;\n}\n\n.section-grid-bg {\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(rgba(0, 255, 136, 0.02) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(0, 255, 136, 0.02) 1px, transparent 1px);\n  background-size: 40px 40px;\n  pointer-events: none;\n}\n\n/* ---------- STATS GRID ---------- */\n.stats-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n  gap: var(--space-md);\n  padding: var(--space-xl) 0;\n}\n\n.stat-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  padding: var(--space-md);\n  text-align: center;\n  transition: all var(--transition-base);\n  position: relative;\n  overflow: hidden;\n}\n\n.stat-card::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, var(--text-accent), transparent);\n  opacity: 0;\n  transition: opacity var(--transition-base);\n}\n\n.stat-card:hover {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 15px var(--glow-accent);\n}\n\n.stat-card:hover::before {\n  opacity: 1;\n}\n\n.stat-card .stat-icon {\n  margin-bottom: var(--space-xs);\n}\n\n.stat-card .stat-icon svg {\n  width: 20px;\n  height: 20px;\n  fill: var(--text-accent);\n  margin: 0 auto;\n}\n\n.stat-number {\n  font-family: var(--font-mono);\n  font-size: 1.6rem;\n  font-weight: 700;\n  color: var(--text-accent);\n  text-shadow: 0 0 10px var(--glow-accent);\n  line-height: 1;\n}\n\n.stat-label {\n  font-family: var(--font-mono);\n  font-size: 0.65rem;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.2em;\n  margin-top: var(--space-xs);\n}\n\n/* ---------- ABOUT INTRO ---------- */\n.about-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: var(--space-xl);\n}\n\n.about-text h3 {\n  font-family: var(--font-heading);\n  font-size: 1.2rem;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  color: var(--text-heading);\n  margin-bottom: var(--space-sm);\n}\n\n.about-text p {\n  color: var(--text-muted);\n  margin-bottom: var(--space-md);\n  font-size: 0.85rem;\n}\n\n/* ---------- SKILLS ---------- */\n.skills-list {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: var(--space-md);\n}\n\n.skill-row {\n  display: flex;\n  align-items: flex-start;\n  gap: var(--space-md);\n  padding: var(--space-md);\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  transition: all var(--transition-base);\n}\n\n.skill-row:hover {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 10px var(--glow-accent);\n}\n\n.skill-icon {\n  flex-shrink: 0;\n  width: 36px;\n  height: 36px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  background: var(--bg-secondary);\n}\n\n.skill-icon svg {\n  width: 18px;\n  height: 18px;\n  fill: var(--text-accent);\n}\n\n.skill-info h4 {\n  font-family: var(--font-heading);\n  font-size: 0.95rem;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  color: var(--text-heading);\n  margin-bottom: 2px;\n}\n\n.skill-info p {\n  font-size: 0.75rem;\n  color: var(--text-muted);\n  line-height: 1.5;\n}\n\n/* ---------- EXPERIENCE TIMELINE ---------- */\n.timeline {\n  position: relative;\n  padding-left: var(--space-lg);\n}\n\n.timeline::before {\n  content: '';\n  position: absolute;\n  left: 6px;\n  top: 0;\n  bottom: 0;\n  width: 1px;\n  background: linear-gradient(to bottom, var(--text-accent), var(--border-subtle));\n}\n\n.timeline-entry {\n  position: relative;\n  margin-bottom: var(--space-xl);\n  padding: var(--space-md);\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  transition: all var(--transition-base);\n}\n\n.timeline-entry:hover {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 12px var(--glow-accent);\n}\n\n.timeline-entry::before {\n  content: '';\n  position: absolute;\n  left: calc(-1 * var(--space-lg) + 3px);\n  top: var(--space-md);\n  width: 7px;\n  height: 7px;\n  background: var(--text-accent);\n  border-radius: 50%;\n  box-shadow: 0 0 6px var(--glow-accent-strong);\n}\n\n.timeline-date {\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  letter-spacing: 0.1em;\n  margin-bottom: var(--space-xs);\n}\n\n.timeline-entry h3 {\n  font-family: var(--font-heading);\n  font-size: 1.1rem;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: var(--text-heading);\n}\n\n.timeline-entry h4 {\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  color: var(--text-accent);\n  font-weight: 400;\n  margin-bottom: var(--space-sm);\n}\n\n.timeline-entry p {\n  font-size: 0.8rem;\n  color: var(--text-muted);\n  margin-bottom: var(--space-sm);\n}\n\n/* ---------- FEATURED PROJECTS ---------- */\n.projects-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\n  gap: var(--space-md);\n}\n\n.project-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  padding: var(--space-lg);\n  display: flex;\n  flex-direction: column;\n  transition: all var(--transition-base);\n  position: relative;\n  overflow: hidden;\n}\n\n.project-card::after {\n  content: '';\n  position: absolute;\n  bottom: 0;\n  left: 0;\n  right: 0;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, var(--text-accent), transparent);\n  opacity: 0;\n  transition: opacity var(--transition-base);\n}\n\n.project-card:hover {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 20px var(--glow-accent);\n  transform: translateY(-2px);\n}\n\n.project-card:hover::after {\n  opacity: 1;\n}\n\n.project-card-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: var(--space-sm);\n}\n\n.project-card-header svg {\n  width: 22px;\n  height: 22px;\n  fill: var(--text-accent);\n}\n\n.project-external svg {\n  width: 14px;\n  height: 14px;\n  fill: var(--text-muted);\n  transition: fill var(--transition-fast);\n}\n\n.project-card:hover .project-external svg {\n  fill: var(--text-accent);\n}\n\n.project-card h3 {\n  font-family: var(--font-heading);\n  font-size: 1.15rem;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  color: var(--text-heading);\n  margin-bottom: var(--space-xs);\n}\n\n.project-desc {\n  font-size: 0.8rem;\n  color: var(--text-muted);\n  flex: 1;\n  margin-bottom: var(--space-md);\n}\n\n.project-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-xs);\n  margin-bottom: var(--space-md);\n}\n\n.tag {\n  font-family: var(--font-mono);\n  font-size: 0.65rem;\n  color: var(--text-accent);\n  border: 1px solid rgba(0, 255, 136, 0.2);\n  padding: 2px 8px;\n  border-radius: var(--radius);\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n.project-links {\n  display: flex;\n  gap: var(--space-sm);\n  margin-top: auto;\n}\n\n.project-links a {\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  transition: color var(--transition-fast);\n}\n\n.project-links a svg {\n  width: 12px;\n  height: 12px;\n  fill: currentColor;\n}\n\n.project-links a:hover {\n  color: var(--text-accent);\n}\n\n/* ---------- BLOG GRID ---------- */\n.blog-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));\n  gap: var(--space-md);\n}\n\n.blog-card {\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  padding: var(--space-lg);\n  display: flex;\n  flex-direction: column;\n  transition: all var(--transition-base);\n  position: relative;\n}\n\n.blog-card:hover {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 15px var(--glow-accent);\n}\n\n.blog-meta {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: var(--space-sm);\n}\n\n.blog-date {\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  letter-spacing: 0.05em;\n}\n\n.blog-read-time {\n  font-family: var(--font-mono);\n  font-size: 0.65rem;\n  color: var(--text-accent);\n  border: 1px solid rgba(0, 255, 136, 0.2);\n  padding: 2px 6px;\n  border-radius: var(--radius);\n}\n\n.blog-card h3 {\n  font-family: var(--font-heading);\n  font-size: 1.05rem;\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  color: var(--text-heading);\n  margin-bottom: var(--space-sm);\n  line-height: 1.3;\n}\n\n.blog-card h3 a {\n  color: inherit;\n  transition: color var(--transition-fast);\n}\n\n.blog-card h3 a:hover {\n  color: var(--text-accent);\n}\n\n.blog-excerpt {\n  font-size: 0.8rem;\n  color: var(--text-muted);\n  flex: 1;\n  margin-bottom: var(--space-md);\n}\n\n.blog-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-xs);\n}\n\n/* ---------- CSS-ONLY LOAD MORE ---------- */\n.load-more-wrapper {\n  text-align: center;\n  margin-top: var(--space-xl);\n  position: relative;\n}\n\n.load-more-checkbox {\n  display: none;\n}\n\n.blog-grid-hidden {\n  display: none;\n}\n\n.load-more-checkbox:checked ~ .blog-grid-hidden {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));\n  gap: var(--space-md);\n  animation: fadeIn 0.5s ease forwards;\n}\n\n.load-more-checkbox:checked ~ .load-more-wrapper .btn {\n  display: none;\n}\n\n/* ---------- CONTACT ---------- */\n.contact-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: var(--space-xl);\n}\n\n.contact-info p {\n  font-size: 0.85rem;\n  color: var(--text-muted);\n  margin-bottom: var(--space-lg);\n}\n\n.contact-links {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-sm);\n}\n\n.contact-link {\n  display: flex;\n  align-items: center;\n  gap: var(--space-sm);\n  padding: var(--space-sm) var(--space-md);\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  font-family: var(--font-mono);\n  font-size: 0.8rem;\n  color: var(--text-primary);\n  transition: all var(--transition-fast);\n}\n\n.contact-link svg {\n  width: 16px;\n  height: 16px;\n  fill: var(--text-accent);\n  flex-shrink: 0;\n}\n\n.contact-link:hover {\n  border-color: var(--text-accent);\n  color: var(--text-accent);\n  box-shadow: 0 0 10px var(--glow-accent);\n}\n\n.contact-form-wrapper {\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  padding: var(--space-lg);\n}\n\n.contact-form-wrapper h3 {\n  font-family: var(--font-heading);\n  font-size: 1rem;\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  color: var(--text-heading);\n  margin-bottom: var(--space-md);\n}\n\n.form-group {\n  margin-bottom: var(--space-md);\n}\n\n.form-group label {\n  display: block;\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n  text-transform: uppercase;\n  letter-spacing: 0.1em;\n  margin-bottom: var(--space-xs);\n}\n\n.form-group input,\n.form-group textarea {\n  width: 100%;\n  padding: 0.6rem 0.8rem;\n  background: var(--bg-secondary);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  color: var(--text-primary);\n  font-family: var(--font-mono);\n  font-size: 0.85rem;\n  outline: none;\n  transition: border-color var(--transition-fast);\n}\n\n.form-group input:focus,\n.form-group textarea:focus {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 8px var(--glow-accent);\n}\n\n.form-group textarea {\n  min-height: 100px;\n  resize: vertical;\n}\n\n/* ---------- FOOTER ---------- */\n.footer {\n  border-top: 1px solid var(--border-subtle);\n  padding: var(--space-lg) 0;\n}\n\n.footer-inner {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-sm);\n}\n\n.footer-brand {\n  font-family: var(--font-heading);\n  font-size: 0.85rem;\n  text-transform: uppercase;\n  letter-spacing: 0.15em;\n  color: var(--text-accent);\n}\n\n.footer-copy {\n  font-family: var(--font-mono);\n  font-size: 0.7rem;\n  color: var(--text-muted);\n}\n\n/* ---------- BACK TO TOP (CSS-only via :target) ---------- */\n.back-to-top {\n  position: fixed;\n  bottom: var(--space-lg);\n  right: var(--space-lg);\n  z-index: 100;\n}\n\n.back-to-top a {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 40px;\n  height: 40px;\n  background: var(--bg-card);\n  border: 1px solid var(--border-subtle);\n  border-radius: var(--radius);\n  transition: all var(--transition-fast);\n}\n\n.back-to-top a svg {\n  width: 16px;\n  height: 16px;\n  fill: var(--text-muted);\n}\n\n.back-to-top a:hover {\n  border-color: var(--text-accent);\n  box-shadow: 0 0 10px var(--glow-accent);\n}\n\n.back-to-top a:hover svg {\n  fill: var(--text-accent);\n}\n\n/* ---------- RESPONSIVE — TABLET ---------- */\n@media (min-width: 768px) {\n  .about-grid {\n    grid-template-columns: 1.2fr 1fr;\n  }\n\n  .skills-list {\n    grid-template-columns: 1fr 1fr;\n  }\n\n  .contact-grid {\n    grid-template-columns: 1fr 1fr;\n  }\n}\n\n/* ---------- RESPONSIVE — DESKTOP ---------- */\n@media (min-width: 1024px) {\n  .nav-inner {\n    padding: 0 var(--space-lg);\n  }\n\n  .container {\n    padding: 0 var(--space-lg);\n  }\n\n  .hero {\n    min-height: 90vh;\n  }\n\n  .stats-grid {\n    grid-template-columns: repeat(5, 1fr);\n  }\n\n  .skills-list {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .projects-grid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n\n  .blog-grid {\n    grid-template-columns: repeat(3, 1fr);\n  }\n}\n\n/* ---------- RESPONSIVE — LARGE ---------- */\n@media (min-width: 1440px) {\n  :root {\n    --max-width: 1320px;\n  }\n}\n\n/* ---------- REDUCED MOTION ---------- */\n@media (prefers-reduced-motion: reduce) {\n  *,\n  *::before,\n  *::after {\n    animation-duration: 0.01ms !important;\n    animation-iteration-count: 1 !important;\n    transition-duration: 0.01ms !important;\n  }\n}\n",
